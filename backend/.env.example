# Server Configuration
HOST=0.0.0.0
PORT=1337

# Secrets (Generate these randomly in production)
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Database (PostgreSQL for Production)
# Leave DATABASE_CLIENT blank to fallback to SQLite for local dev
DATABASE_CLIENT=postgres
DATABASE_URL=postgres://user:password@hostname:5432/dbname

# Cloudinary (Required for media storage on Render/Railway)
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret

# Selzy Email Configuration
SELZY_API_KEY=your_selzy_api_key
SELZY_DEFAULT_FROM=hello@neuron.com
SELZY_DEFAULT_REPLY_TO=hello@neuron.com
