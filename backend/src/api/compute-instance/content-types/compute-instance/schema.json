{
  "kind": "collectionType",
  "collectionName": "compute_instances",
  "info": {
    "singularName": "compute-instance",
    "pluralName": "compute-instances",
    "displayName": "Compute Instance"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string"
    },
    "gpu_type": {
      "type": "string"
    },
    "hourly_rate": {
      "type": "decimal"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "available",
        "rented",
        "offline"
      ],
      "default": "available"
    }
  }
}